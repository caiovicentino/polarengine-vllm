+static __global__ void dequantize_block_pq3_0(const void * __restrict__ vx, float * __restrict__ y, const int64_t k) {
+    const int64_t i = (int64_t)blockIdx.x * blockDim.x + threadIdx.x;
+    if (i >= k) return;
+
+    const int block_idx = i / QK_PQ3_0;
+    const int val_idx = i % QK_PQ3_0;
+    const block_pq3_0 * x = (const block_pq3_0 *)vx + block_idx;
