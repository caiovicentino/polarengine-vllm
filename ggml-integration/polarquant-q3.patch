+// Vec dot: pq3_0 x q8_0 via dequantize-then-dot
+// Used for attention: Q(float/q8) . K(pq3_0)
+void ggml_vec_dot_pq3_0_q8_0(int n, float * GGML_RESTRICT s, size_t bs,
+                               const void * GGML_RESTRICT vx, size_t bx,
+                               const void * GGML_RESTRICT vy, size_t by, int nrc) {
+    assert(n % QK_PQ3_0 == 0);
+    assert(nrc == 1);
+    UNUSED(bs); UNUSED(bx); UNUSED(by); UNUSED(nrc);
+
+    const block_pq3_0 * GGML_RESTRICT x = (const block_pq3_0 *)vx;
+    const block_q8_0 * GGML_RESTRICT y = (const block_q8_0 *)vy;
+
+    const int nb = n / QK_PQ3_0;
+    float sumf = 0.0f;
+
+    for (int i = 0; i < nb; i++) {
+        // Dequantize PQ3 block
+        float dequant[QK_PQ3_0];
+        dequantize_row_pq3_0(x + i, dequant, QK_PQ3_0);
+
+        // Dot with Q8_0 blocks (QK_PQ3_0/QK8_0 = 4 Q8 blocks per PQ3 block)
+        for (int j = 0; j < QK_PQ3_0 / QK8_0; j++) {
+            const int q8_idx = i * (QK_PQ3_0 / QK8_0) + j;
+            const float d8 = GGML_CPU_FP16_TO_FP32(y[q8_idx].d);
+            float block_sum = 0.0f;
+            for (int k = 0; k < QK8_0; k++) {
+                block_sum += dequant[j * QK8_0 + k] * (float)y[q8_idx].qs[k];
+            }
+            sumf += block_sum * d8;
+        }
+    }
+
+    *s = sumf;
+}
