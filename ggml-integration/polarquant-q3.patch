+
+// ====================== PolarQuant Q3 (Hadamard-rotated Lloyd-Max 3-bit) ======================
+
+// Fast Walsh-Hadamard Transform (in-place, O(n log n))
+// Self-inverse (orthogonal + symmetric): FWHT = IFWHT
+static void pq3_fwht_128(float * x) {
+    // 7 butterfly stages for n=128 (log2(128) = 7)
+    for (int len = 1; len < QK_PQ3_0; len <<= 1) {
+        for (int i = 0; i < QK_PQ3_0; i += len << 1) {
+            for (int j = 0; j < len; j++) {
+                float u = x[i + j];
+                float v = x[i + j + len];
+                x[i + j]       = u + v;
+                x[i + j + len] = u - v;
+            }
+        }
+    }
+    const float s = 1.0f / sqrtf((float)QK_PQ3_0);
+    for (int i = 0; i < QK_PQ3_0; i++) {
+        x[i] *= s;
+    }
+}
+
+// Lloyd-Max optimal centroids for N(0,1) at 3 bits (8 levels)
+static const float PQ3_CENTROIDS[8] = {
+    -2.1519461f, -1.3439096f, -0.7560055f, -0.2450942f,
+     0.2450942f,  0.7560055f,  1.3439096f,  2.1519461f
+};
+
+// Pack 3-bit codes: 8 codes (3 bits each) → 3 bytes
+static void pq3_pack_3bit(const uint8_t * codes, uint8_t * packed, int n) {
+    for (int i = 0; i < n; i += 8) {
+        uint8_t c0 = codes[i+0], c1 = codes[i+1], c2 = codes[i+2], c3 = codes[i+3];
+        uint8_t c4 = codes[i+4], c5 = codes[i+5], c6 = codes[i+6], c7 = codes[i+7];
+        int j = (i / 8) * 3;
+        packed[j+0] = (c0 << 5) | (c1 << 2) | (c2 >> 1);
+        packed[j+1] = ((c2 & 1) << 7) | (c3 << 4) | (c4 << 1) | (c5 >> 2);
+        packed[j+2] = ((c5 & 3) << 6) | (c6 << 3) | c7;
+    }
+}
+
+// Unpack 3-bit codes: 3 bytes → 8 codes (3 bits each)
+static void pq3_unpack_3bit(const uint8_t * packed, uint8_t * codes, int n) {
+    for (int i = 0; i < n; i += 8) {
+        int j = (i / 8) * 3;
+        uint8_t b0 = packed[j+0], b1 = packed[j+1], b2 = packed[j+2];
+        codes[i+0] = (b0 >> 5) & 7;
+        codes[i+1] = (b0 >> 2) & 7;
+        codes[i+2] = ((b0 & 3) << 1) | ((b1 >> 7) & 1);
+        codes[i+3] = (b1 >> 4) & 7;
+        codes[i+4] = (b1 >> 1) & 7;
+        codes[i+5] = ((b1 & 1) << 2) | ((b2 >> 6) & 3);
+        codes[i+6] = (b2 >> 3) & 7;
+        codes[i+7] = b2 & 7;
+    }
+}
+
+// reference implementation for deterministic creation of model files
+void quantize_row_pq3_0_ref(const float * GGML_RESTRICT x, block_pq3_0 * GGML_RESTRICT y, int64_t k) {
+    static const int qk = QK_PQ3_0;
+
+    assert(k % qk == 0);
+
+    const int64_t nb = k / qk;
+
+    for (int64_t i = 0; i < nb; i++) {
+        float buf[QK_PQ3_0];
+
+        // 1. Compute L2 norm
+        float norm_sq = 0.0f;
+        for (int j = 0; j < qk; j++) {
+            norm_sq += x[i*qk + j] * x[i*qk + j];
+        }
+        float norm = sqrtf(norm_sq);
+        if (norm < 1e-10f) norm = 1e-10f;
+
+        y[i].d = GGML_FP32_TO_FP16(norm);
+
+        // 2. Normalize
+        const float inv_norm = 1.0f / norm;
+        for (int j = 0; j < qk; j++) {
+            buf[j] = x[i*qk + j] * inv_norm;
+        }
+
+        // 3. Walsh-Hadamard transform (decorrelate)
+        pq3_fwht_128(buf);
+
+        // 4. Scale by sqrt(block_size) for Lloyd-Max
+        const float scale = sqrtf((float)qk);  // 11.3137...
+        for (int j = 0; j < qk; j++) {
+            buf[j] *= scale;
+        }
+
+        // 5. Lloyd-Max quantize: find nearest centroid
+        uint8_t codes[QK_PQ3_0];
+        for (int j = 0; j < qk; j++) {
+            float val = buf[j];
+            int best = 0;
+            float best_dist = fabsf(val - PQ3_CENTROIDS[0]);
+            for (int c = 1; c < 8; c++) {
+                float dist = fabsf(val - PQ3_CENTROIDS[c]);
+                if (dist < best_dist) {
+                    best_dist = dist;
+                    best = c;
+                }
+            }
+            codes[j] = (uint8_t)best;
+        }
+
+        // 6. Bit-pack 128 codes → 48 bytes
+        pq3_pack_3bit(codes, y[i].qs, qk);
+    }
+}
+
+void dequantize_row_pq3_0(const block_pq3_0 * GGML_RESTRICT x, float * GGML_RESTRICT y, int64_t k) {
+    static const int qk = QK_PQ3_0;
+
+    assert(k % qk == 0);
+
+    const int64_t nb = k / qk;
+
+    for (int64_t i = 0; i < nb; i++) {
+        float buf[QK_PQ3_0];
+
+        // 1. Unpack 3-bit codes
+        uint8_t codes[QK_PQ3_0];
+        pq3_unpack_3bit(x[i].qs, codes, qk);
+
+        // 2. Centroid lookup + descale
+        const float inv_scale = 1.0f / sqrtf((float)qk);
+        for (int j = 0; j < qk; j++) {
+            buf[j] = PQ3_CENTROIDS[codes[j]] * inv_scale;
+        }
+
+        // 3. Inverse Walsh-Hadamard transform (FWHT is self-inverse)
+        pq3_fwht_128(buf);
+
+        // 4. Denormalize
+        const float norm = GGML_FP16_TO_FP32(x[i].d);
+        for (int j = 0; j < qk; j++) {
+            y[i*qk + j] = buf[j] * norm;
+        }
+    }
+}
+
+size_t quantize_pq3_0(const float * GGML_RESTRICT src, void * GGML_RESTRICT dst,
+                      int64_t nrows, int64_t n_per_row, const float * imatrix) {
+    (void)imatrix; // not used
+    const size_t row_size = ggml_row_size(GGML_TYPE_PQ3_0, n_per_row);
+    for (int64_t row = 0; row < nrows; row++) {
+        quantize_row_pq3_0_ref(src + row * n_per_row,
+                               (block_pq3_0 *)((char *)dst + row * row_size),
+                               n_per_row);
+    }
+    return nrows * row_size;
+}
