+    switch (bit_pos) {
+        case 0: code = (packed[0] >> 5) & 7; break;
+        case 1: code = (packed[0] >> 2) & 7; break;
+        case 2: code = ((packed[0] & 3) << 1) | ((packed[1] >> 7) & 1); break;
+        case 3: code = (packed[1] >> 4) & 7; break;
+        case 4: code = (packed[1] >> 1) & 7; break;
+        case 5: code = ((packed[1] & 1) << 2) | ((packed[2] >> 6) & 3); break;
+        case 6: code = (packed[2] >> 3) & 7; break;
